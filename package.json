{
  "name": "ibm-z-hex-on-editor",
  "displayName": "IBM Z HEX ON Editor",
  "description": "Edit IBM Z file bytes in an ISPF-style HEX ON view with IBM EBCDIC DBCS preview and SO/SI diagnostics.",
  "version": "0.1.0",
  "publisher": "nicholas-yahung-chien",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0D0D0F",
    "theme": "dark"
  },
  "keywords": [
    "IBM Z",
    "z/OS",
    "HEX ON",
    "EBCDIC",
    "IBM-930",
    "IBM-937",
    "IBM-939",
    "DBCS",
    "hex editor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nicholas-yahung-chien/ibm-z-hexeditor.git"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ibmZHexEditor.openHexOn",
    "onCustomEditor:ibmZHexEditor.hexOn"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ibmZHexEditor.openHexOn",
        "title": "IBM Z Hex Editor: Open HEX ON",
        "category": "IBM Z Hex Editor"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ibmZHexEditor.openHexOn",
          "group": "navigation@90",
          "when": "editorTextFocus"
        }
      ],
      "editor/context": [
        {
          "command": "ibmZHexEditor.openHexOn",
          "group": "navigation@90",
          "when": "editorTextFocus"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "ibmZHexEditor.hexOn",
        "displayName": "IBM Z HEX ON Editor",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "IBM Z HEX ON Editor",
      "properties": {
        "ibmZHexEditor.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "minimum": 1,
          "description": "Maximum local file size, in KB, that can be opened in the HEX ON editor."
        },
        "ibmZHexEditor.condenseMode": {
          "type": "boolean",
          "default": false,
          "description": "Show a denser HEX ON grid with narrower byte cells, hidden offsets, and no grid edge padding."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "node scripts/clean.mjs",
    "compile": "npm run clean && npm run build:extension && npm run build:webview",
    "build:extension": "node scripts/build-extension.mjs",
    "build:webview": "vite build --config vite.config.mjs",
    "generate:code-pages": "node scripts/generate-ucm-tables.mjs",
    "package:vsix": "vsce package --out dist/ibm-z-hex-on-editor.vsix",
    "watch": "npm-run-all --parallel watch:extension watch:webview",
    "watch:extension": "node scripts/build-extension.mjs --watch",
    "watch:webview": "vite build --watch --config vite.config.mjs",
    "test": "vitest run --config vitest.config.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.36",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.100.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.5",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.0"
  }
}
